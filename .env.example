# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── API keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=...

# ── Default provider (claude | openai | deepseek | ollama) ────────────────────
# LLM_PROVIDER=deepseek

# ── DeepSeek models ───────────────────────────────────────────────────────────
# DEEPSEEK_MODEL=deepseek-v4-flash

# ── Default models (optional — overrides the built-in defaults) ───────────────
# ANTHROPIC_MODEL=claude-opus-4-6
# OPENAI_MODEL=gpt-4o
# OLLAMA_MODEL=qwen3.5:latest
# OLLAMA_URL=http://localhost:11434

# ── Extra models added to the dropdown lists ──────────────────────────────────
# Comma-separated.  You can also type any model ID directly in the combobox.
# CLAUDE_EXTRA_MODELS=claude-opus-4-7,claude-sonnet-4-7
# OPENAI_EXTRA_MODELS=o3,o3-mini,gpt-4.1
